# HarvestAlert Frontend Environment Configuration
# Copy this file to .env.local and update with your values
# Validates: Requirements 19.4

# ============================================
# API Configuration (Requirement 19.4)
# ============================================

# Backend API base URL
# For local development:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# For production, update to your production API URL:
# NEXT_PUBLIC_API_BASE_URL=https://api.your-production-domain.com

# ============================================
# Map Configuration (Optional)
# ============================================

# Default map center coordinates (latitude, longitude)
NEXT_PUBLIC_MAP_DEFAULT_CENTER_LAT=0
NEXT_PUBLIC_MAP_DEFAULT_CENTER_LNG=20

# Default map zoom level (1-18, where 1 is world view and 18 is street level)
NEXT_PUBLIC_MAP_DEFAULT_ZOOM=3

# ============================================
# Environment Settings
# ============================================

# Node environment: development or production
NODE_ENV=development

# ============================================
# Optional: Analytics & Monitoring
# ============================================

# Add your analytics or monitoring service keys here
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
