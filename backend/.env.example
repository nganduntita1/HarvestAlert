# HarvestAlert Backend Environment Configuration
# Copy this file to .env and update with your values
# Validates: Requirements 19.1, 19.2, 19.3

# ============================================
# Database Configuration (Requirement 19.1)
# ============================================

# For PostgreSQL (recommended for production):
DATABASE_URL=postgresql://harvestalert:changeme@localhost:5432/harvestalert

# For SQLite (development/testing only):
# DATABASE_URL=sqlite:///./harvestalert.db

# PostgreSQL connection pool settings (optional, only for PostgreSQL)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================
# API Configuration (Requirement 19.2)
# ============================================

# Port the API server will listen on
API_PORT=8000

# Host the API server will bind to
# Use 0.0.0.0 to accept connections from any network interface
# Use 127.0.0.1 for localhost only
API_HOST=0.0.0.0

# ============================================
# CORS Configuration (Requirement 19.3)
# ============================================

# Comma-separated list of allowed origins for CORS
# Add your frontend URL(s) here
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# For production, add your production frontend URL:
# CORS_ORIGINS=http://localhost:3000,https://your-production-domain.com

# ============================================
# Environment Settings
# ============================================

# Environment: development, staging, or production
ENVIRONMENT=development

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
