# HarvestAlert Docker Compose Environment Configuration
# Copy this file to .env and update with your values
# Used by docker-compose.yml for full stack deployment

# ============================================
# Database Configuration
# ============================================

# PostgreSQL database name
POSTGRES_DB=harvestalert

# PostgreSQL username
POSTGRES_USER=harvestalert

# PostgreSQL password (CHANGE THIS IN PRODUCTION!)
POSTGRES_PASSWORD=changeme

# PostgreSQL port (default: 5432)
POSTGRES_PORT=5432

# ============================================
# Backend API Configuration
# ============================================

# API server port
API_PORT=8000

# CORS allowed origins (comma-separated)
# Update with your frontend URL in production
CORS_ORIGINS=http://localhost:3000

# Environment: development, staging, or production
ENVIRONMENT=production

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# Frontend Configuration
# ============================================

# Frontend port
FRONTEND_PORT=3000

# Backend API URL (as seen from the browser)
# For local Docker: http://localhost:8000
# For production: https://api.your-domain.com
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=https://harvestalert-backend.fly.dev

